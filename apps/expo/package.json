{
  "name": "@kosmo/expo",
  "main": "expo-router/entry",
  "type": "module",
  "scripts": {
    "start": "bun ./src/server/index.ts",
    "android": "bun run codegen && expo run:android",
    "ios": "bun run codegen && expo run:ios",
    "web": "bun run codegen && expo start --web",
    "build:web": "bun run codegen && expo export --platform web",
    "lint:expo": "expo lint",
    "lint:tsc": "bun run codegen && tsc --noEmit",
    "serve-web": "bun ./src/server/index.ts",
    "lint": "expo lint",
    "dev": "bun run codegen && expo start",
    "codegen": "mearie generate"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.14",
    "@kosmo/core": "workspace:*",
    "@mearie/react": "^0.4.7",
    "@react-navigation/native": "^7.1.33",
    "expo": "~55.0.12",
    "expo-constants": "~55.0.12",
    "expo-dev-client": "~55.0.27",
    "expo-font": "~55.0.6",
    "expo-linking": "~55.0.11",
    "expo-router": "~55.0.11",
    "expo-server": "^55.0.7",
    "expo-splash-screen": "~55.0.16",
    "expo-status-bar": "~55.0.5",
    "expo-system-ui": "~55.0.14",
    "expo-web-browser": "~55.0.13",
    "hono": "^4.12.14",
    "lucide-react-native": "^1.8.0",
    "nativewind": "5.0.0-preview.3",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.4",
    "react-native-css": "3.0.7",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.7.2",
    "tailwind-merge": "^3.5.0",
    "tailwind-variants": "^3.2.2",
    "tsx": "^4.21.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@types/react": "~19.2.2",
    "eslint-config-expo": "^55.0.0",
    "mearie": "^0.1.7",
    "postcss": "^8.5.10",
    "tailwindcss": "^4.2.2"
  },
  "private": true
}
