{
  "extends": ["expo/tsconfig.base", "../../tsconfig.json"],
  "compilerOptions": {
    "allowImportingTsExtensions": true,
    "jsx": "react-native",
    "module": "Preserve",
    "noEmit": true,
    "paths": {
      "@/*": ["./src/*"]
    },
    "verbatimModuleSyntax": true
  },
  "include": [
    ".expo/types/**/*.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    "src/env.d.ts",
    "nativewind-env.d.ts",
    "expo-env.d.ts"
  ]
}
