require 'digest'
require 'fileutils'
require 'json'
require 'open3'
require 'plist'
require 'set'
require 'shellwords'
require 'tmpdir'

default_platform(:ios)
opt_out_usage

BUNDLE_IDENTIFIER = 'moe.kos'
WORKSPACE_PATH = 'ios/Kosmo.xcworkspace'
SCHEME = 'Kosmo'

def require_environment!(*names)
  missing = names.select { |name| ENV[name].to_s.empty? }
  UI.user_error!("Missing required environment variable(s): #{missing.join(', ')}") unless missing.empty?
end

def build_number!
  build_number = ENV.fetch('IOS_BUILD_NUMBER')
  UI.user_error!('IOS_BUILD_NUMBER must be a positive integer.') unless build_number.match?(/\A[1-9]\d*\z/)

  build_number
end

platform :ios do
  private_lane :validate_release_environment do
    require_environment!(
      'APPLE_DEVELOPER_TEAM_ID',
      'FIREBASE_IOS_APP_ID',
      'FIREBASE_TESTER_GROUP',
      'IOS_ARTIFACT_DIR',
      'MATCH_GIT_PRIVATE_KEY_PATH',
      'MATCH_GIT_URL',
      'MATCH_KEYCHAIN_PASSWORD',
      'MATCH_KEYCHAIN_PATH',
      'MATCH_PASSWORD',
      'RELEASE_NOTES_FILE',
    )
    build_number!
  end

  private_lane :load_apple_api_key do
    require_environment!('APPLE_API_KEY_ID', 'APPLE_API_ISSUER_ID', 'APPLE_API_KEY_PATH')

    app_store_connect_api_key(
      key_id: ENV.fetch('APPLE_API_KEY_ID'),
      issuer_id: ENV.fetch('APPLE_API_ISSUER_ID'),
      key_filepath: ENV.fetch('APPLE_API_KEY_PATH'),
      duration: 1200,
      in_house: false,
    )
  end

  private_lane :create_ephemeral_keychain do
    create_keychain(
      path: ENV.fetch('MATCH_KEYCHAIN_PATH'),
      password: ENV.fetch('MATCH_KEYCHAIN_PASSWORD'),
      default_keychain: false,
      unlock: true,
      timeout: 3600,
      lock_after_timeout: true,
      add_to_search_list: true,
      require_create: true,
    )

    lane_context[SharedValues::KEYCHAIN_PATH] || ENV.fetch('MATCH_KEYCHAIN_PATH')
  end

  private_lane :delete_ephemeral_keychain do |options|
    keychain_path = options.fetch(:path)
    delete_keychain(keychain_path: keychain_path) if File.exist?(keychain_path)
  end

  private_lane :sync_adhoc_signing do |options|
    match_options = {
      app_identifier: BUNDLE_IDENTIFIER,
      clone_branch_directly: true,
      force_for_new_devices: options.fetch(:force_for_new_devices),
      git_branch: 'main',
      git_private_key: ENV.fetch('MATCH_GIT_PRIVATE_KEY_PATH'),
      git_url: ENV.fetch('MATCH_GIT_URL'),
      keychain_name: ENV.fetch('MATCH_KEYCHAIN_PATH'),
      keychain_password: ENV.fetch('MATCH_KEYCHAIN_PASSWORD'),
      readonly: options.fetch(:readonly),
      shallow_clone: true,
      team_id: ENV.fetch('APPLE_DEVELOPER_TEAM_ID'),
      type: 'adhoc',
    }

    if options[:api_key]
      match_options[:api_key] = options[:api_key]
      match_options[:git_full_name] = 'Kosmo iOS signing'
      match_options[:git_user_email] = 'signing@kos.moe'
    end

    match(**match_options)
  end

  private_lane :verify_prebuild_signing do
    require_environment!('APPLE_DEVELOPER_TEAM_ID')

    build_settings = sh(
      "xcodebuild -workspace #{Shellwords.escape(WORKSPACE_PATH)} " \
      "-scheme #{Shellwords.escape(SCHEME)} -configuration Release -showBuildSettings",
    )
    {
      'DEVELOPMENT_TEAM' => ENV.fetch('APPLE_DEVELOPER_TEAM_ID'),
      'PRODUCT_BUNDLE_IDENTIFIER' => BUNDLE_IDENTIFIER,
    }.each do |name, value|
      pattern = /^\s*#{Regexp.escape(name)} = #{Regexp.escape(value)}\s*$/
      UI.user_error!("#{name} does not match the expected iOS signing configuration.") unless build_settings.match?(pattern)
    end
  end

  private_lane :build_adhoc_ipa do
    profile_mapping = lane_context[SharedValues::MATCH_PROVISIONING_PROFILE_MAPPING]
    UI.user_error!('match did not return an Ad Hoc provisioning profile mapping.') if profile_mapping.nil? || profile_mapping.empty?

    build_app(
      clean: true,
      configuration: 'Release',
      export_method: 'ad-hoc',
      export_options: { provisioningProfiles: profile_mapping },
      output_directory: ENV.fetch('IOS_ARTIFACT_DIR'),
      output_name: 'Kosmo.ipa',
      scheme: SCHEME,
      workspace: WORKSPACE_PATH,
    )
  end

  private_lane :verify_adhoc_ipa do |options|
    ipa_path = File.expand_path(options.fetch(:ipa_path))
    UI.user_error!("IPA was not created at #{ipa_path}.") unless File.file?(ipa_path)

    team_id = ENV.fetch('APPLE_DEVELOPER_TEAM_ID')
    expected_build_number = build_number!

    Dir.mktmpdir('kosmo-ipa-') do |directory|
      sh("unzip -qq #{Shellwords.escape(ipa_path)} -d #{Shellwords.escape(directory)}")
      app_bundle = Dir[File.join(directory, 'Payload', '*.app')].first
      UI.user_error!('IPA does not contain an app bundle.') unless app_bundle

      info = Plist.parse_xml(File.join(app_bundle, 'Info.plist'))
      UI.user_error!('IPA Info.plist is missing.') unless info
      UI.user_error!('IPA bundle identifier does not match moe.kos.') unless info['CFBundleIdentifier'] == BUNDLE_IDENTIFIER
      UI.user_error!('IPA build number does not match IOS_BUILD_NUMBER.') unless info['CFBundleVersion'] == expected_build_number

      provisioning_profile = File.join(app_bundle, 'embedded.mobileprovision')
      UI.user_error!('IPA does not embed a provisioning profile.') unless File.file?(provisioning_profile)

      profile_plist = File.join(directory, 'embedded.mobileprovision.plist')
      sh(
        "security cms -D -i #{Shellwords.escape(provisioning_profile)} " \
        "> #{Shellwords.escape(profile_plist)}",
      )
      profile = Plist.parse_xml(profile_plist)
      UI.user_error!('Embedded provisioning profile is invalid.') unless profile
      UI.user_error!('Embedded provisioning profile has a different team.') unless Array(profile['TeamIdentifier']).include?(team_id)
      UI.user_error!('Embedded provisioning profile has a different app identifier.') unless profile.dig('Entitlements', 'application-identifier') == "#{team_id}.#{BUNDLE_IDENTIFIER}"
      UI.user_error!('Embedded provisioning profile is not an Ad Hoc profile.') if profile['ProvisionsAllDevices'] || profile.dig('Entitlements', 'get-task-allow')

      profile_devices = Array(profile['ProvisionedDevices'])
      UI.user_error!('Embedded provisioning profile has no registered devices.') if profile_devices.empty?

      expected_devices_file = ENV['IOS_REQUIRED_UDIDS_FILE']
      if expected_devices_file && !expected_devices_file.empty?
        expected_devices = File.foreach(expected_devices_file).drop(1).filter_map do |line|
          device_id = line.split("\t", 2).first.to_s.strip
          device_id unless device_id.empty?
        end.to_set
        UI.user_error!('Embedded provisioning profile omits a registered tester device.') unless expected_devices.subset?(profile_devices.to_set)
      end

      signing_output = sh("codesign --display --verbose=4 #{Shellwords.escape(app_bundle)} 2>&1")
      sh("codesign --verify --deep --strict --verbose=2 #{Shellwords.escape(app_bundle)}")
      UI.user_error!('IPA signing team does not match the provisioning profile.') unless signing_output.match?(/TeamIdentifier=#{Regexp.escape(team_id)}(?:\s|$)/)
      UI.user_error!('IPA is not signed with an Apple distribution certificate.') unless signing_output.match?(/^Authority=(?:Apple|iPhone) Distribution/m)
    end
  end

  private_lane :verify_newer_than_firebase_release do
    latest_release = firebase_app_distribution_get_latest_release(app: ENV.fetch('FIREBASE_IOS_APP_ID'))
    return unless latest_release

    latest_build_number = Integer(latest_release.fetch(:buildVersion))
    UI.user_error!('IOS_BUILD_NUMBER is not newer than the latest Firebase iOS release.') unless build_number!.to_i > latest_build_number
  end

  private_lane :upload_ipa_to_firebase do |options|
    firebase_app_distribution(
      app: ENV.fetch('FIREBASE_IOS_APP_ID'),
      groups: ENV.fetch('FIREBASE_TESTER_GROUP'),
      ipa_path: options.fetch(:ipa_path),
      release_notes_file: ENV.fetch('RELEASE_NOTES_FILE'),
    )
  end

  lane :release_adhoc do
    validate_release_environment
    keychain_path = create_ephemeral_keychain

    begin
      verify_prebuild_signing
      sync_adhoc_signing(readonly: true, force_for_new_devices: false)
      ipa_path = build_adhoc_ipa
      verify_adhoc_ipa(ipa_path: ipa_path)
      verify_newer_than_firebase_release
      upload_ipa_to_firebase(ipa_path: ipa_path)
    ensure
      delete_ephemeral_keychain(path: keychain_path) if keychain_path
    end
  end

  lane :onboard_devices do
    validate_release_environment
    udids_file = ENV.fetch('IOS_REQUIRED_UDIDS_FILE')
    keychain_path = nil

    begin
      FileUtils.rm_f(udids_file)
      firebase_app_distribution_get_udids(app: ENV.fetch('FIREBASE_IOS_APP_ID'), output_file: udids_file)
      UI.user_error!('Firebase has no registered tester UDIDs to onboard.') unless File.file?(udids_file) && File.size?(udids_file)

      api_key = load_apple_api_key
      register_devices(
        api_key: api_key,
        devices_file: udids_file,
        team_id: ENV.fetch('APPLE_DEVELOPER_TEAM_ID'),
      )

      keychain_path = create_ephemeral_keychain
      verify_prebuild_signing
      sync_adhoc_signing(
        api_key: api_key,
        force_for_new_devices: true,
        readonly: false,
      )
      ipa_path = build_adhoc_ipa
      verify_adhoc_ipa(ipa_path: ipa_path)
      verify_newer_than_firebase_release
      upload_ipa_to_firebase(ipa_path: ipa_path)
    ensure
      delete_ephemeral_keychain(path: keychain_path) if keychain_path
      FileUtils.rm_f(udids_file)
    end
  end
end

ANDROID_APP_ROOT = File.expand_path('..', __dir__)
ANDROID_DIRECTORY = File.join(ANDROID_APP_ROOT, 'android')
ANDROID_PACKAGE = 'moe.kos'

def android_required_environment(name)
  value = ENV.fetch(name, '').strip
  UI.user_error!("#{name} is required") if value.empty?
  value
end

def android_run_command!(*command)
  output, status = Open3.capture2e(*command, chdir: ANDROID_APP_ROOT)
  UI.user_error!("#{command.first} failed:\n#{output}") unless status.success?
  output
end

def android_run_command_with_environment!(environment, *command)
  output, status = Open3.capture2e(environment, *command, chdir: ANDROID_APP_ROOT)
  UI.user_error!("#{command.first} failed:\n#{output}") unless status.success?
  output
end

def android_run_adb!(*arguments)
  output, status = Open3.capture2e(android_required_environment('ANDROID_ADB'), *arguments)
  UI.user_error!("adb #{arguments.join(' ')} failed:\n#{output}") unless status.success?
  output
end

def android_run_adb_probe(*arguments)
  Open3.capture2e(android_required_environment('ANDROID_ADB'), *arguments)
end

def android_normalized_fingerprint(value)
  fingerprint = value.delete(':').upcase
  UI.user_error!('Android certificate SHA-256 fingerprint is invalid') unless fingerprint.match?(/\A[0-9A-F]{64}\z/)
  fingerprint
end

def android_release_config
  expo_config = JSON.parse(android_run_command!('pnpm', 'exec', 'expo', 'config', '--type', 'public', '--json'))
  package_name = expo_config.fetch('android').fetch('package')
  UI.user_error!("Android package must remain #{ANDROID_PACKAGE}") unless package_name == ANDROID_PACKAGE

  build_number = Integer(android_required_environment('KOSMO_ANDROID_BUILD_NUMBER'), 10)
  UI.user_error!('KOSMO_ANDROID_BUILD_NUMBER must allow a predecessor build') if build_number < 2

  source_commit = android_required_environment('KOSMO_SOURCE_COMMIT')
  UI.user_error!('KOSMO_SOURCE_COMMIT must be a full Git SHA') unless source_commit.match?(/\A[0-9a-f]{40}\z/)

  tester_group = android_required_environment('FIREBASE_TESTER_GROUP')
  UI.user_error!('FIREBASE_TESTER_GROUP must be a group alias, not tester emails') if tester_group.include?('@') || tester_group.include?(',')

  {
    apk_analyzer: android_required_environment('ANDROID_APKANALYZER'),
    apksigner: android_required_environment('ANDROID_APKSIGNER'),
    app_id: android_required_environment('FIREBASE_ANDROID_APP_ID'),
    build_number: build_number,
    expected_fingerprint: android_normalized_fingerprint(android_required_environment('ANDROID_RELEASE_CERTIFICATE_SHA256')),
    marketing_version: expo_config.fetch('version'),
    metadata_path: android_required_environment('KOSMO_RELEASE_METADATA_PATH'),
    predecessor_apk: android_required_environment('KOSMO_ANDROID_PREDECESSOR_APK'),
    release_notes: android_required_environment('KOSMO_RELEASE_NOTES'),
    run_url: android_required_environment('KOSMO_ACTIONS_RUN_URL'),
    source_commit: source_commit,
    tester_group: tester_group,
  }
end

def android_build_release!(version_code)
  android_run_command_with_environment!(
    { 'KOSMO_ANDROID_VERSION_CODE' => version_code.to_s },
    'pnpm',
    'exec',
    'expo',
    'prebuild',
    '--clean',
    '--platform',
    'android',
    '--no-install',
  )

  gradle(
    task: 'assemble',
    build_type: 'Release',
    project_dir: ANDROID_DIRECTORY,
    flags: '--no-daemon',
    print_command: false,
  )

  apk = File.join(ANDROID_DIRECTORY, 'app/build/outputs/apk/release/app-release.apk')
  UI.user_error!('Release APK was not created') unless File.file?(apk) && File.size?(apk)
  apk
end

def android_verify_apk!(config, apk, expected_version_code)
  package_name = android_run_command!(config[:apk_analyzer], 'manifest', 'application-id', apk).strip
  version_code = android_run_command!(config[:apk_analyzer], 'manifest', 'version-code', apk).strip
  version_name = android_run_command!(config[:apk_analyzer], 'manifest', 'version-name', apk).strip
  UI.user_error!("APK package ID mismatch: #{package_name}") unless package_name == ANDROID_PACKAGE
  UI.user_error!("APK versionCode mismatch: #{version_code}") unless version_code == expected_version_code.to_s
  UI.user_error!("APK versionName mismatch: #{version_name}") unless version_name == config[:marketing_version]

  verification = android_run_command!(config[:apksigner], 'verify', '--verbose', '--print-certs', apk)
  actual_fingerprint = verification[/certificate SHA-256 digest:\s*([0-9A-Fa-f:]+)/i, 1]
  UI.user_error!('APK signing certificate was not found') unless actual_fingerprint
  unless android_normalized_fingerprint(actual_fingerprint) == config[:expected_fingerprint]
    UI.user_error!('APK signing certificate fingerprint mismatch')
  end
end

def android_selected_device!
  requested = ENV.fetch('KOSMO_ANDROID_DEVICE_SERIAL', '').strip
  devices = android_run_adb!('devices').lines.filter_map do |line|
    serial, state = line.split(/\s+/, 2)
    serial if state&.strip == 'device'
  end

  if requested.empty?
    UI.user_error!('Exactly one connected Android test device is required') unless devices.one?
    return devices.first
  end

  UI.user_error!('Requested Android test device is not connected') unless devices.include?(requested)
  requested
end

def android_installed_version_code(serial)
  output = android_run_adb!('-s', serial, 'shell', 'dumpsys', 'package', ANDROID_PACKAGE)
  output[/versionCode=(\d+)/, 1]&.to_i
end

def android_wait_for_running!(serial)
  10.times do
    output, status = android_run_adb_probe('-s', serial, 'shell', 'pidof', ANDROID_PACKAGE)
    return if status.success? && !output.strip.empty?

    sleep 1
  end

  UI.user_error!('Android app did not stay running after launch')
end

def android_verify_install_and_update!(config, predecessor_apk, release_apk)
  serial = android_selected_device!
  installed_before = android_installed_version_code(serial)

  if installed_before.nil?
    android_run_adb!('-s', serial, 'install', predecessor_apk)
    predecessor_version = android_installed_version_code(serial)
    unless predecessor_version == config[:build_number] - 1
      UI.user_error!('Android predecessor install did not set the expected versionCode')
    end
  elsif installed_before >= config[:build_number]
    UI.user_error!("Android test device already has versionCode #{installed_before}; run a newer distribution")
  end

  android_run_adb!('-s', serial, 'install', '-r', release_apk)
  installed_after = android_installed_version_code(serial)
  UI.user_error!('Android update did not set the expected versionCode') unless installed_after == config[:build_number]
  android_run_adb!('-s', serial, 'shell', 'monkey', '-p', ANDROID_PACKAGE, '1')
  android_wait_for_running!(serial)
end

def android_verify_wif_adc!
  credentials_path = android_required_environment('GOOGLE_APPLICATION_CREDENTIALS')
  UI.user_error!('Google ADC file does not exist') unless File.file?(credentials_path)
  credentials = JSON.parse(File.read(credentials_path))
  UI.user_error!('Firebase upload must use WIF Application Default Credentials') unless credentials['type'] == 'external_account'
  credentials_path
end

def android_release_value(release, name)
  release[name] || release[name.to_s]
end

def android_write_metadata!(config, apk, release)
  firebase_console_uri = android_release_value(release, :firebaseConsoleUri)
  testing_uri = android_release_value(release, :testingUri)
  UI.user_error!('Firebase release did not return its console URL') unless firebase_console_uri
  UI.user_error!('Firebase release did not return its tester URL') unless testing_uri

  metadata = {
    artifact_sha256: Digest::SHA256.file(apk).hexdigest,
    artifact_size_bytes: File.size(apk),
    firebase_console_uri: firebase_console_uri,
    package_name: ANDROID_PACKAGE,
    signer_sha256: config[:expected_fingerprint],
    source_commit: config[:source_commit],
    testing_uri: testing_uri,
    version_code: config[:build_number],
    version_name: config[:marketing_version],
    workflow_url: config[:run_url],
  }
  FileUtils.mkdir_p(File.dirname(config[:metadata_path]), mode: 0o700)
  File.write(config[:metadata_path], JSON.generate(metadata))
  File.chmod(0o600, config[:metadata_path])
end

platform :android do
  desc 'Build, verify, install, update, and distribute a signed Android Release APK'
  lane :distribute do
    config = android_release_config

    begin
      android_run_command!('pnpm', 'relay')

      predecessor_apk = android_build_release!(config[:build_number] - 1)
      FileUtils.cp(predecessor_apk, config[:predecessor_apk])
      android_verify_apk!(config, config[:predecessor_apk], config[:build_number] - 1)

      release_apk = android_build_release!(config[:build_number])
      android_verify_apk!(config, release_apk, config[:build_number])
      android_verify_install_and_update!(config, config[:predecessor_apk], release_apk)

      credentials_path = android_verify_wif_adc!
      release = firebase_app_distribution(
        app: config[:app_id],
        android_artifact_path: release_apk,
        android_artifact_type: 'APK',
        groups: config[:tester_group],
        release_notes: config[:release_notes],
        service_credentials_file: credentials_path,
      )
      android_write_metadata!(config, release_apk, release)
    ensure
      FileUtils.rm_rf(ANDROID_DIRECTORY)
    end
  end
end
