{
  "name": "@kosmo/app",
  "private": true,
  "version": "0.0.1",
  "main": "expo-router/entry",
  "scripts": {
    "android": "expo run:android",
    "build": "pnpm export:web",
    "build-storybook": "storybook build --disable-telemetry",
    "check": "pnpm relay && tsc --noEmit",
    "dev": "pnpm relay && expo start --port 5173",
    "export:web": "pnpm relay && expo export --clear --platform web",
    "ios": "expo run:ios",
    "lint:relay": "relay-compiler",
    "lint:tsc": "pnpm relay && tsc --noEmit",
    "prepare": "pnpm relay",
    "relay": "relay-compiler",
    "relay:watch": "relay-compiler --watch",
    "start": "expo start",
    "storybook:dev": "storybook dev -p 6006 --disable-telemetry",
    "test:storybook": "vitest run --project=storybook",
    "test:unit": "node --import tsx --test 'src/**/*.test.ts'",
    "web": "expo start --web --port 5173"
  },
  "dependencies": {
    "@kosmo/core": "workspace:*",
    "@sun-typeface/suit": "^2.0.5",
    "expo": "~56.0.14",
    "expo-auth-session": "~56.0.15",
    "expo-constants": "~56.0.20",
    "expo-crypto": "~56.0.4",
    "expo-font": "~56.0.7",
    "expo-linking": "~56.0.15",
    "expo-router": "~56.2.13",
    "expo-secure-store": "~56.0.4",
    "expo-splash-screen": "~56.0.12",
    "expo-status-bar": "~56.0.4",
    "expo-system-ui": "~56.0.5",
    "expo-web-browser": "~56.0.5",
    "lucide-react-native": "^1.23.0",
    "pretendard": "^1.3.9",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-reanimated": "~4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-svg": "^15.15.4",
    "react-native-web": "~0.21.2",
    "react-native-worklets": "~0.8.3",
    "react-relay": "^21.0.1",
    "relay-runtime": "^21.0.1"
  },
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@react-native/metro-config": "0.85.3",
    "@storybook/addon-a11y": "^10.4.6",
    "@storybook/addon-vitest": "10.4.6",
    "@storybook/react-vite": "^10.4.6",
    "@types/react": "~19.2.15",
    "@types/react-relay": "18.2.1",
    "@vitest/browser-playwright": "4.1.8",
    "babel-plugin-relay": "^21.0.1",
    "babel-preset-expo": "~56.0.16",
    "playwright": "^1.60.0",
    "relay-compiler": "^21.0.1",
    "storybook": "^10.4.6",
    "tsx": "^4.22.4",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  }
}
