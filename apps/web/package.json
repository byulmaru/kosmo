{
  "name": "@kosmo/web",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "storybook": "storybook dev -p 6006 --disable-telemetry",
    "build-storybook": "storybook build --disable-telemetry",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "test:unit": "vitest",
    "test": "npm run test:unit -- --run && npm run test:e2e",
    "test:e2e": "playwright install && playwright test",
    "start": "node build/index.js"
  },
  "devDependencies": {
    "@kosmo/core": "workspace:*",
    "@lucide/svelte": "^1.17.0",
    "@mearie/core": "^0.6.7",
    "@mearie/svelte": "^0.4.7",
    "@playwright/test": "^1.59.1",
    "@storybook/addon-a11y": "^10.4.2",
    "@storybook/addon-docs": "^10.4.2",
    "@storybook/addon-svelte-csf": "^5.1.2",
    "@storybook/addon-vitest": "^10.4.2",
    "@storybook/sveltekit": "^10.4.2",
    "@sveltejs/adapter-node": "^5.5.4",
    "@sveltejs/kit": "^2.63.0",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@tailwindcss/vite": "^4.2.2",
    "@tiptap/core": "^3.24.0",
    "@tiptap/extension-document": "^3.24.0",
    "@tiptap/extension-paragraph": "^3.24.0",
    "@tiptap/extension-text": "^3.24.0",
    "@vitest/browser-playwright": "^4.1.8",
    "@vitest/coverage-v8": "^4.1.8",
    "bits-ui": "^2.18.1",
    "cookie": "^1.1.1",
    "mearie": "^0.1.7",
    "playwright": "^1.59.1",
    "storybook": "^10.4.2",
    "svelte": "^5.55.7",
    "svelte-check": "^4.4.6",
    "tailwind-merge": "^3.6.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.2.2",
    "vite": "^8.0.7",
    "vitest": "^4.1.8",
    "vitest-browser-svelte": "^2.1.1",
    "zod": "^4.4.3"
  }
}
