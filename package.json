{
  "name": "@kosmo/monorepo",
  "private": true,
  "version": "0.0.0",
  "packageManager": "bun",
  "scripts": {
    "dev": "infisical run -- bun run --parallel --workspaces --if-present dev",
    "lint:eslint": "eslint --max-warnings 0 .",
    "lint:prettier": "prettier --check --ignore-unknown '**/*'",
    "lint:syncpack": "syncpack lint --dependency-types prod,dev,peer",
    "prepare": "husky || true"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bun": "^1.3.12",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "ms": "^2.1.3",
    "prettier": "^3.8.2",
    "prettier-plugin-brace-style": "^0.10.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "syncpack": "^14.3.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0",
    "unrs-resolver": "^1.11.1"
  },
  "overrides": {
    "lightningcss": "1.30.1"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "patchedDependencies": {
    "@react-native/gradle-plugin@0.83.4": "patches/@react-native%2Fgradle-plugin@0.83.4.patch"
  }
}
